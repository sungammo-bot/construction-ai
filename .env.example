# Supabase — find these under Project Settings > API in your Supabase dashboard
# (your project: https://supabase.com/dashboard/project/nmufxelukboqamknwvpd)
NEXT_PUBLIC_SUPABASE_URL=https://nmufxelukboqamknwvpd.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role key — server-side only, NEVER expose to the browser. Used by the
# ingest-snapshot API route to write data on behalf of the camera/n8n pipeline.
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic — used server-side to analyse each snapshot
ANTHROPIC_API_KEY=

# Shared secret that n8n (or whatever posts snapshots) must send in the
# x-ingest-secret header when calling /api/ingest-snapshot. Make up a long
# random string and put the same value in your n8n HTTP Request node.
INGEST_API_SECRET=
